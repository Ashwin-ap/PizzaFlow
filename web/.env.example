# ── Supabase ────────────────────────────────────────────────
# New-format API keys (sb_publishable_ / sb_secret_). The publishable key is
# browser-safe (RLS-guarded); the secret key is SERVER ONLY — never NEXT_PUBLIC.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx                 # SERVER ONLY

# ── OpenRouter (Feature A — Phase 5) ────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxx                   # SERVER ONLY
OPENROUTER_MODEL=meta-llama/llama-4-scout:free     # :free = $0 — verify slug on openrouter.ai/models
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Forecast service (Feature C — Phase 7, optional) ────────
# Local dev: run the Python service (see forecast-service/README) and point this at it.
FORECAST_SERVICE_URL=http://localhost:8000         # prod: https://<render-app>.onrender.com
FORECAST_SERVICE_TOKEN=<shared-secret>             # must match forecast-service FORECAST_SERVICE_TOKEN
CRON_SECRET=<random-hex>                           # guards POST /api/cron/forecast

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

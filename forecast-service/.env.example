# Forecast service env (Feature C). Copy to forecast-service/.env for local runs.
# The service uses the service-role secret (bypasses RLS) to read orders + write forecasts.

# Same bare project URL as the web app's NEXT_PUBLIC_SUPABASE_URL
SUPABASE_URL=https://<project-ref>.supabase.co

# Same value as the web app's SUPABASE_SECRET_KEY (sb_secret_...). Server-only, never in a browser.
SUPABASE_SERVICE_KEY=<service-role-secret-key>

# Shared secret; must equal the web app's FORECAST_SERVICE_TOKEN. Guards POST /train.
FORECAST_SERVICE_TOKEN=<shared-secret>
